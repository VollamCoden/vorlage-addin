<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
  xsi:type="TaskPaneApp">

  <!-- WICHTIG: IHRE-URL durch die tatsächliche Hosting-URL ersetzen -->
  <!-- z.B. https://meinefirma.sharepoint.com/sites/tools/vorlage-addin -->

  <Id>3A7B9F24-6E51-4D28-BC93-F1A205E8D742</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Intern</ProviderName>
  <DefaultLocale>de-DE</DefaultLocale>
  <DisplayName DefaultValue="Vorlage ausfüllen"/>
  <Description DefaultValue="Platzhalter [Name] im Dokument automatisch ausfüllen"/>
  <IconUrl DefaultValue="https://IHRE-URL/vorlage-addin/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://IHRE-URL/vorlage-addin/icon-80.png"/>
  <SupportUrl DefaultValue="https://IHRE-URL"/>

  <AppDomains/>

  <Hosts>
    <Host Name="Document"/>
  </Hosts>

  <DefaultSettings>
    <SourceLocation DefaultValue="https://IHRE-URL/vorlage-addin/taskpane.html"/>
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
                    xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Document">
        <DesktopFormFactor>
          <GetStarted>
            <Title resid="GetStarted.Title"/>
            <Description resid="GetStarted.Description"/>
            <LearnMoreUrl resid="LearnMoreUrl"/>
          </GetStarted>
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="VorlageGroup">
                <Label resid="Group.Label"/>
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16"/>
                  <bt:Image size="32" resid="Icon.32x32"/>
                  <bt:Image size="80" resid="Icon.80x80"/>
                </Icon>
                <Control xsi:type="Button" id="VorlageButton">
                  <Label resid="Button.Label"/>
                  <Supertip>
                    <Title resid="Button.Label"/>
                    <Description resid="Button.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>VorlagePane</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://IHRE-URL/vorlage-addin/icon-16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://IHRE-URL/vorlage-addin/icon-32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://IHRE-URL/vorlage-addin/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="LearnMoreUrl"  DefaultValue="https://IHRE-URL"/>
        <bt:Url id="Taskpane.Url" DefaultValue="https://IHRE-URL/vorlage-addin/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GetStarted.Title"  DefaultValue="Vorlage ausfüllen"/>
        <bt:String id="Group.Label"       DefaultValue="Vorlagen"/>
        <bt:String id="Button.Label"      DefaultValue="Ausfüllen"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="GetStarted.Description" DefaultValue="Platzhalter [Name] im Dokument automatisch ausfüllen."/>
        <bt:String id="Button.Tooltip"         DefaultValue="Öffnet das Formular zum Ausfüllen der Platzhalter [Name] im Dokument."/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
